@context: E-commerce purchase flow on SauceDemo
@title: swag-labs-checkout
@var: {username} = standard_user
@var: {password} = secret_sauce

STEP 1: Login
    # 📍 Auto-Nav: https://www.saucedemo.com/
    NAVIGATE to https://www.saucedemo.com/
    FILL 'Username' field with '{username}'
    FILL 'Password' field with '{password}'
    CLICK 'Login' button
    WAIT 2

STEP 2: Add item to cart
    # 📍 Auto-Nav: Products Catalog
    VERIFY that 'Products' is present
    # NEAR qualifier: resolves the 'Sauce Labs Fleece Jacket' text first,
    # then prefers the matching 'Add to cart' button in the same product card,
    # using both visual distance and DOM container affinity.
    CLICK 'Add to cart' button NEAR 'Sauce Labs Fleece Jacket'

STEP 3: Review cart
    # 📍 Auto-Nav: Shopping Cart
    CLICK the 'Shopping cart' link
    VERIFY that 'Sauce Labs Fleece Jacket' is present
    CLICK 'Checkout' button

STEP 4: Fill shipping info
    # 📍 Auto-Nav: Checkout: Your Info
    FILL 'First Name' field with 'FirstName'
    FILL 'Last Name' field with 'LastName'
    FILL 'Zip/Postal Code' field with '49000'
    CLICK 'Continue' button

STEP 5: Complete order
    # 📍 Auto-Nav: Checkout: Overview
    CLICK 'Finish' button
    # 📍 Auto-Nav: Checkout: Complete
    VERIFY that 'Thank you for your order!' is present
DONE.
